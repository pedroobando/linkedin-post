# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_NAME=Coach360
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==========================================
# AUTHENTICATION (Better Auth)
# ==========================================
# Generate secrets with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_JWT_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=["http://localhost:3000"]

# Admin Token - Generate with: openssl rand -base64 32
ADMIN_API_TOKEN=your-secret-here

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USER=coach360
DB_PASSWORD=your-password-here
DB_NAME=coach360
DATABASE_URL=postgresql://coach360:your-password-here@localhost:5446/coach360
CONTAINER_NAMEDB=coach360-pg

# ==========================================
# MINIO OBJECT STORAGE
# ==========================================
# MinIO root credentials (for bucket creation/management)
MINIO_ROOT_USER=admin@gmail.com
MINIO_ROOT_PASSWORD=your-minio-password-here
MINIO_CONTAINER=coach360-minio

# MinIO application credentials (for app access)
# Access key: openssl rand -hex 10 (20 chars)
MINIO_ACCESS_KEY=your-access-key-here
# Secret key: openssl rand -hex 20 (40 chars)  
MINIO_SECRET_KEY=your-secret-key-here

# MinIO configuration (internal Docker network)
MINIO_ENDPOINT=bucket
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=coach360-uploads

# ==========================================
# TODO: REDIS CACHE (FASE 2)
# ==========================================
# NOTA: Agregar contenedor Redis para caché de sesiones de Better Auth
# REDIS_URL=redis://localhost:6379
# CONTAINER_NAMEREDIS=coach360-redis
# Esto mejorará el rendimiento de las sesiones y autenticación
